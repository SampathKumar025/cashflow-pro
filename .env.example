# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.

DATABASE_URL="file:./dev.db"

# Gmail SMTP for sending OTP emails.
# SMTP_USER = the Gmail address that sends the mail.
# SMTP_PASS = a Google "App Password" (16 chars, no spaces), NOT your normal
#             Gmail password. Generate at: Google Account > Security >
#             2-Step Verification > App passwords.
SMTP_USER="your-address@gmail.com"
SMTP_PASS="your-16-char-app-password"

# Secret used to sign session JWTs. Use a long random string.
JWT_SECRET="change-me-to-a-long-random-string"
